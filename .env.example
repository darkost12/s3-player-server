# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# bcrypt cost factor for hashing passwords — higher is slower but more secure (12 is a good default)
SALT_ROUNDS=12

# Random secret for signing session cookies — use a long random string
SESSION_SECRET=change_me_to_something_random

S3_BUCKET=bucket-name
S3_ENDPOINT=storage.net
S3_REGION=eu-central1

# Path prefix inside the bucket where audio files live (include trailing slash)
S3_SUBPATH=music/

# Path prefix for YAML metadata/lyrics files (include trailing slash)
S3_METADATA=metadata/

# Whether to use path-style URLs (e.g. http://endpoint/bucket/key) instead of virtual-hosted-style (e.g. http://bucket.endpoint/key)
FORCE_PATH_STYLE=true

# Leave empty for a public bucket; fill in for a private bucket
S3_ACCESS_KEY=
S3_SECRET_KEY=
